{
  "name": "token-lens",
  "displayName": "Token Lens",
  "description": "Live token efficiency monitor for Claude Code sessions",
  "version": "0.0.1",
  "publisher": "token-lens",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "token-lens",
          "title": "Token Lens",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "token-lens": [
        {
          "type": "webview",
          "id": "tokenLens.panel",
          "name": "Token Lens"
        }
      ]
    },
    "commands": [
      {
        "command": "tokenLens.refresh",
        "title": "Token Lens: Refresh"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "chokidar": "^3.5.3"
  }
}
